# Copy this file to ".env" and fill in your key. ".env" is git-ignored.

# Required: your Fireworks API key (any OpenAI-compatible key works).
LLM_API_KEY=fw_...

# OpenAI-compatible endpoint. Default is Fireworks.
LLM_BASE_URL=https://api.fireworks.ai/inference/v1

# Models. Default to Fireworks gpt-oss-120b for all stages; override per stage.
# Fireworks hosts many models — swap these for a larger/stronger one for generation if you like.
MATCH_MODEL=accounts/fireworks/models/gpt-oss-120b
GENERATE_MODEL=accounts/fireworks/models/gpt-oss-120b
IMPORT_MODEL=accounts/fireworks/models/gpt-oss-120b

# Optional: max output tokens per call (generation can be large).
MAX_TOKENS=8000

# Optional: pricing used only for the cost estimate printed after each run ($ per 1M tokens).
PRICE_INPUT_PER_M=0.15
PRICE_OUTPUT_PER_M=0.60

# Optional: scoring weights (normalized automatically). Industry is the rule of thumb.
WEIGHT_INDUSTRY=0.5
WEIGHT_SKILL=0.3
WEIGHT_LOCATION=0.2

# Web backend: shared access token bidders must enter to use the platform.
# Leave blank to disable auth (local dev only). Set a long random value in production.
ACCESS_TOKEN=

# Optional: persist the application log to a private GitHub gist so it survives Render's
# ephemeral disk. Leave blank for local-only (log resets on restart). Generated PDFs are
# always local/ephemeral. Token: a GitHub PAT with the "gist" scope, owned by the same
# account as the gist. Create an empty private gist; its id (the URL hash) goes in GIST_ID.
GIST_TOKEN=
GIST_ID=
# Optional: filename inside the gist (default applications.csv).
GIST_FILENAME=applications.csv
